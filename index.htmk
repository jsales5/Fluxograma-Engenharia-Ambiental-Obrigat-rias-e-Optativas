<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Engenharia Ambiental - UnB</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header>
        <h1>Engenharia Ambiental - UnB</h1>
        <p>Acompanhamento de Fluxo Curricular</p>
    </header>

    <h2 class="titulo-sessao">Matriz Obrigatória</h2>
    <main id="grade-container">
        <div class="semestre">
            <h2>1º Nível</h2>
            <div class="materia verde" id="CEL0088">CEL0088 - BIOLOGIA GERAL <input type="checkbox"></div>
            <div class="materia verde" id="ENC0263">ENC0263 - INTROD. ENG. AMBIENTAL <input type="checkbox"></div>
            <div class="materia vermelho" id="IFD0171">IFD0171 - FISICA 1 <input type="checkbox"></div>
            <div class="materia amarelo" id="IFD0173">IFD0173 - FISICA 1 EXP <input type="checkbox"></div>
            <div class="materia azul" id="IGD0173">IGD0173 - GEOLOGIA BÁSICA <input type="checkbox"></div>
            <div class="materia verde" id="IQD0125">IQD0125 - QUIMICA GERAL <input type="checkbox"></div>
            <div class="materia vermelho" id="MAT0025">MAT0025 - CÁLCULO 1 <input type="checkbox"></div>
        </div>

        <div class="semestre">
            <h2>2º Nível</h2>
            <div class="materia verde" id="ECL0033">ECL0033 - ECOLOGIA 1 <input type="checkbox"></div>
            <div class="materia branca" id="ENC0053">ENC0053 - DESENHO TECNICO <input type="checkbox"></div>
            <div class="materia vermelho" id="IFD0175">IFD0175 - FISICA 2 <input type="checkbox"></div>
            <div class="materia amarelo" id="IFD0177">IFD0177 - FISICA 2 EXP <input type="checkbox"></div>
            <div class="materia vermelho" id="MAT0026">MAT0026 - CÁLCULO 2 <input type="checkbox"></div>
            <div class="materia vermelho" id="MAT0031">MAT0031 - INTROD. ALGEBRA LINEAR <input type="checkbox"></div>
        </div>

        <div class="semestre">
            <h2>3º Nível</h2>
            <div class="materia laranja" id="ENC0035">ENC0035 - MEC. SÓLIDOS <input type="checkbox"></div>
            <div class="materia amarelo" id="ENC0240">ENC0240 - LAB. GEOTECNIA 1 <input type="checkbox"></div>
            <div class="materia azul" id="ENC0241">ENC0241 - GEOTECNIA 1 <input type="checkbox"></div>
            <div class="materia azul" id="ENC0266">ENC0266 - CLIMATOLOGIA <input type="checkbox"></div>
            <div class="materia laranja" id="ENC0267">ENC0267 - CARTOGRAFIA <input type="checkbox"></div>
            <div class="materia verde" id="ENC0268">ENC0268 - CIÊNCIA MATERIAIS <input type="checkbox"></div>
            <div class="materia vermelho" id="MAT0027">MAT0027 - CÁLCULO 3 <input type="checkbox"></div>
        </div>

        <div class="semestre">
            <h2>4º Nível</h2>
            <div class="materia vermelho" id="ENC0037">ENC0037 - TRANSF. ENERGIA <input type="checkbox"></div>
            <div class="materia azul" id="ENC0235">ENC0235 - GEOTECNIA 2 <input type="checkbox"></div>
            <div class="materia verde" id="ENC0269">ENC0269 - MICROB. AMBIENTAL <input type="checkbox"></div>
            <div class="materia amarelo" id="ENC0270">ENC0270 - MICROB. EXP <input type="checkbox"></div>
            <div class="materia verde" id="ENC0272">ENC0272 - QUALIDADE ÁGUA <input type="checkbox"></div>
            <div class="materia amarelo" id="ENC0273">ENC0273 - QUALIDADE ÁGUA EXP <input type="checkbox"></div>
        </div>

        <div class="semestre">
            <h2>5º Nível</h2>
            <div class="materia azul" id="ENC0183">ENC0183 - GEOTECNIA AMB. <input type="checkbox"></div>
            <div class="materia azul" id="ENC0251">ENC0251 - HIDRAULICA <input type="checkbox"></div>
            <div class="materia amarelo" id="ENC0252">ENC0252 - HIDRAULICA EXP <input type="checkbox"></div>
            <div class="materia vermelho" id="ENC0274">ENC0274 - ESTATISTICA <input type="checkbox"></div>
            <div class="materia vermelho" id="ENC0275">ENC0275 - MET. COMPUTACIONAIS <input type="checkbox"></div>
            <div class="materia cinza" id="SOL0042">SOL0042 - SOCIOLOGIA <input type="checkbox"></div>
        </div>

        <div class="semestre">
            <h2>6º Nível</h2>
            <div class="materia verde" id="ENC0001">ENC0001 - CINÉTICA/PROCESSOS <input type="checkbox"></div>
            <div class="materia cinza" id="ENC0002">ENC0002 - ECONOMIA AMB. <input type="checkbox"></div>
            <div class="materia azul" id="ENC0166">ENC0166 - HIDROLOGIA <input type="checkbox"></div>
            <div class="materia vermelho" id="ENE0001">ENE0001 - ELETRICIDADE <input type="checkbox"></div>
            <div class="materia cinza" id="EPR0068">EPR0068 - ORG. INDUSTRIAL <input type="checkbox"></div>
        </div>

        <div class="semestre">
            <h2>7º Nível</h2>
            <div class="materia verde" id="ENC0004">ENC0004 - SANEAMENTO <input type="checkbox"></div>
            <div class="materia verde" id="ENC0007">ENC0007 - AGUAS RESIDUARIAS <input type="checkbox"></div>
            <div class="materia verde" id="ENC0010">ENC0010 - TRATAMENTO AGUA <input type="checkbox"></div>
            <div class="materia azul" id="ENC0052">ENC0052 - RESIDUOS SOLIDOS <input type="checkbox"></div>
            <div class="materia cinza" id="EPR0059">EPR0059 - HIGIENE/SEGURANÇA <input type="checkbox"></div>
            <div class="materia cinza" id="FDD0282">FDD0282 - DIREITO AMBIENTAL <input type="checkbox"></div>
        </div>

        <div class="semestre">
            <h2>8º Nível</h2>
            <div class="materia verde" id="ENC0013">ENC0013 - SISTEMAS AMB. <input type="checkbox"></div>
            <div class="materia verde" id="ENC0015">ENC0015 - POLUIÇÃO ÁGUA <input type="checkbox"></div>
            <div class="materia verde" id="ENC0016">ENC0016 - POLUIÇÃO SOLO <input type="checkbox"></div>
            <div class="materia roxo" id="ENC0025">ENC0025 - ESTÁGIO <input type="checkbox"></div>
        </div>

        <div class="semestre">
            <h2>9º Nível</h2>
            <div class="materia verde" id="ENC0026">ENC0026 - IMPACTOS/RISCOS <input type="checkbox"></div>
            <div class="materia roxo" id="ENC0028">ENC0028 - PROJETO 1 <input type="checkbox"></div>
        </div>

        <div class="semestre">
            <h2>10º Nível</h2>
            <div class="materia roxo" id="ENC0030">ENC0030 - PROJETO 2 <input type="checkbox"></div>
            <div class="materia verde" id="ENC0031">ENC0031 - GESTÃO AMB. <input type="checkbox"></div>
        </div>
    </main>

    <hr class="divisor">

    <h2 class="titulo-sessao">Disciplinas Optativas</h2>
    <section id="optativas-container">
        <div class="semestre">
            <h2>Optativas</h2>
            <div class="materia verde" id="CDS0007">CDS0007 - DESENV. SUSTENTAVEL <input type="checkbox"></div>
            <div class="materia verde" id="CDS0008">CDS0008 - MEIO AMB. CULTURA <input type="checkbox"></div>
            <div class="materia verde" id="CEL0019">CEL0019 - BIOQUIMICA/BIOFISICA <input type="checkbox"></div>
            <div class="materia verde" id="CEL0054">CEL0054 - BIOQUIMICA FUND. <input type="checkbox"></div>
            <div class="materia cinza" id="CET0039">CET0039 - SUSTENT. TURISMO <input type="checkbox"></div>
            <div class="materia vermelho" id="CIC0007">CIC0007 - INTROD. COMPUTAÇÃO <input type="checkbox"></div>
            <div class="materia roxo" id="DEG0201">DEG0201 - ATIV. COMPL. <input type="checkbox"></div>
            <div class="materia roxo" id="DEX0199">DEX0199 - ATIV. EXTENSÃO <input type="checkbox"></div>
            <div class="materia cinza" id="DSC0050">DSC0050 - POL. PUBLICAS SAUDE <input type="checkbox"></div>
            <div class="materia cinza" id="ECL0036">ECL0036 - EDUCAÇÃO AMBIENTAL <input type="checkbox"></div>
            <div class="materia verde" id="ENC0003">ENC0003 - SAUDE/SANEAMENTO <input type="checkbox"></div>
            <div class="materia azul" id="ENC0011">ENC0011 - MODELOS/SIMULAÇÃO <input type="checkbox"></div>
            <div class="materia azul" id="ENC0051">ENC0051 - SIST. ESGOTO <input type="checkbox"></div>
            <div class="materia laranja" id="ENC0188">ENC0188 - INVEST. GEOTECNICA <input type="checkbox"></div>
            <div class="materia azul" id="ENC0169">ENC0169 - SIST. HIDRAULICOS <input type="checkbox"></div>
            <div class="materia laranja" id="ENC0271">ENC0271 - MAT. CONSTRUÇÃO 1 <input type="checkbox"></div>
            <div class="materia vermelho" id="ENE0002">ENE0002 - LAB. ELETRICIDADE <input type="checkbox"></div>
            <div class="materia verde" id="FAV0215">FAV0215 - ENERGIA RENOVAVEL <input type="checkbox"></div>
            <div class="materia vermelho" id="MAT0048">MAT0048 - EQUACOES DIF. 1 <input type="checkbox"></div>
        </div>
    </section>

    <script src="script.js"></script>
</body>
</html>
